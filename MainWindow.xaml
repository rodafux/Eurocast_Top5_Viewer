<Window x:Class="Eurocast_Top5_Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Eurocast_Top5_Viewer.ViewModels"
        Title="Top5 Dashboard" WindowStyle="None" WindowState="Maximized" Topmost="True" Background="#0F172A">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="VerticalSeparator" TargetType="Border">
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,2,0"/>
            <Setter Property="Margin" Value="0,8,20,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock Text="TABLEAU DE BORD QUALITÉ" Foreground="#F8FAFC" FontSize="38" FontWeight="Light" Margin="0,0,40,0"/>

                <TextBlock Text="■ Non conforme" Foreground="#EF4444" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,25,0"/>
                <TextBlock Text="■ À améliorer" Foreground="#F59E0B" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,25,0"/>
                <TextBlock Text="■ Validé (pendant 1H)" Foreground="#10B981" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock Text="{Binding PageIndicatorText}" Foreground="#38BDF8" FontSize="26" FontWeight="Black" Margin="0,0,30,0"/>
                <TextBlock Text="{Binding LastUpdateText}" Foreground="#64748B" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding DashboardItems}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Border Margin="0,15,0,0" Padding="15,10" Background="{Binding BackgroundColor}" BorderBrush="{Binding AccentColor}" BorderThickness="6,0,0,0" CornerRadius="0,6,0,0" Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding MachineInfo}" Foreground="{Binding TextColor}" FontSize="32" FontWeight="Bold"/>
                        </Border>

                        <Border Margin="0,0,0,2" Background="{Binding BackgroundColor}" BorderBrush="{Binding AccentColor}" BorderThickness="6,0,0,0" Visibility="{Binding IsNotHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="15,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource VerticalSeparator}"/>
                                <Border Grid.Column="1" Style="{StaticResource VerticalSeparator}"/>
                                <Border Grid.Column="2" Style="{StaticResource VerticalSeparator}"/>

                                <TextBlock Grid.Column="0" Text="{Binding CreationDateStr}" Foreground="{Binding TextColor}" FontSize="24" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                                    <TextBlock Text="{Binding DefectDisplay}" Foreground="{Binding TextColor}" FontSize="26" FontWeight="Bold" TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding CoreAlertText}" Foreground="#EF4444" FontSize="20" FontWeight="Black" TextWrapping="Wrap" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Comment}" Foreground="{Binding TextColor}" FontSize="24" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                <TextBlock Grid.Column="3" Text="{Binding ElapsedTime}" Foreground="{Binding TextColor}" FontSize="26" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>