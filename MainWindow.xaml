<Window x:Class="Eurocast_Top5_Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Eurocast_Top5_Viewer.ViewModels"
        Title="Top5 Dashboard Qualité (Appuyez sur F11 pour le Plein Écran)" 
        WindowStyle="SingleBorderWindow" WindowState="Normal" Background="#061224"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="LegendBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LegendText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlashLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FlashValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock Text="DASHBOARD QUALITÉ" Foreground="#F8FAFC" FontSize="42" FontWeight="Light" Margin="0,0,40,0"/>

                <StackPanel Orientation="Horizontal" Visibility="{Binding IsDefectsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,4">
                    <Border Style="{StaticResource LegendBadge}" Background="#E53935">
                        <TextBlock Text="Non conforme" Style="{StaticResource LegendText}"/>
                    </Border>
                    <Border Style="{StaticResource LegendBadge}" Background="#FFB300">
                        <TextBlock Text="À améliorer" Style="{StaticResource LegendText}"/>
                    </Border>
                    <Border Style="{StaticResource LegendBadge}" Background="#10B981">
                        <TextBlock Text="Validé" Style="{StaticResource LegendText}" Foreground="#061224"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,4">
                <TextBlock Text="{Binding PageIndicatorText}" Foreground="#00E5FF" FontSize="24" FontWeight="Bold" Margin="0,0,25,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LastUpdateText}" Foreground="#00E5FF" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <StackPanel Orientation="Horizontal" Visibility="{Binding IsWindowed, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Command="{Binding PrevPageCommand}" Content="&#x23EE; PRÉC." Style="{StaticResource NavButton}"/>
                    <Button Command="{Binding TogglePauseCommand}" Content="{Binding PausePlayText}" Style="{StaticResource NavButton}"/>
                    <Button Command="{Binding NextPageCommand}" Content="SUIV. &#x23ED;" Style="{StaticResource NavButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding DashboardItems}" Visibility="{Binding IsDefectsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid Margin="0,15,0,5" Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="24" Height="24" Fill="{Binding MachineColor}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding MachineInfo}" Foreground="#00E5FF" FontSize="32" FontWeight="Bold"/>
                            <Border Grid.ColumnSpan="2" BorderBrush="#00E5FF" BorderThickness="0,0,0,2" Margin="0,40,0,0"/>
                        </Grid>

                        <Border Margin="40,2,0,2" Height="50" Background="{Binding BackgroundColor}" Visibility="{Binding IsNotHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="30" Margin="0,0,15,0" Background="{Binding AccentColor}" CornerRadius="4,0,0,4" />

                                <TextBlock Grid.Column="1" Text="{Binding CreationDateStr}" Foreground="{Binding TextColor}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding DefectDisplay}" Foreground="{Binding TextColor}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,20,0"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                    <TextBlock Text="{Binding Comment}" Foreground="{Binding TextColor}" FontSize="22" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding CoreAlertText}" Foreground="#EF4444" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="4" Text="{Binding ElapsedTime}" Foreground="{Binding TextColor}" FontSize="24" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="1" Margin="0,15,0,0" Background="#1E293B" CornerRadius="8" BorderBrush="#EF4444" BorderThickness="6,0,0,0" Visibility="{Binding IsFlashVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="30" DataContext="{Binding CurrentFlashDetail}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="⚠️ FLASH QUALITÉ N° " Foreground="#EF4444" FontSize="42" FontWeight="Black"/>
                    <TextBlock Text="{Binding Id}" Foreground="#EF4444" FontSize="42" FontWeight="Black"/>
                    <TextBlock Text=" - " Foreground="#EF4444" FontSize="42" FontWeight="Black" Margin="10,0,10,0"/>
                    <TextBlock Text="{Binding DateStr}" Foreground="#EF4444" FontSize="42" FontWeight="Black"/>
                    <TextBlock Text="{Binding Origine, StringFormat=' ({0})'}" Foreground="#F8FAFC" FontSize="36" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#334155" CornerRadius="6" Padding="20" Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="CLIENT" Style="{StaticResource FlashLabel}"/>
                            <TextBlock Text="{Binding Client}" Foreground="#38BDF8" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="RÉFÉRENCE" Style="{StaticResource FlashLabel}"/>
                            <TextBlock Text="{Binding Reference}" Foreground="#F8FAFC" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="DÉSIGNATION" Style="{StaticResource FlashLabel}"/>
                            <TextBlock Text="{Binding Designation}" Foreground="#F8FAFC" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,30,0" CornerRadius="6" ClipToBounds="True" Background="#0F172A" BorderBrush="#334155" BorderThickness="2" VerticalAlignment="Stretch">
                        <Image Source="{Binding DefectImageUrl}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="⯈ LIBELLÉ DU DÉFAUT" Foreground="#F59E0B" FontSize="24" FontWeight="Black" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding LibelleDefaut}" Style="{StaticResource FlashValue}"/>

                        <TextBlock Text="⯈ CONSÉQUENCES" Foreground="#EF4444" FontSize="24" FontWeight="Black" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Consequences}" Style="{StaticResource FlashValue}"/>

                        <Border Background="#0F172A" BorderBrush="#10B981" BorderThickness="4,0,0,0" Padding="20">
                            <StackPanel>
                                <TextBlock Text="PLAN DE RÉACTION" Foreground="#10B981" FontSize="24" FontWeight="Black" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding PlanReaction}" Foreground="#A7F3D0" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>